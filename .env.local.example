# Database (local SQLite for dev, D1 on Cloudflare)
DATABASE_URL="file:./local.db"

# Encryption key for GitHub tokens
CRYPTO_KEY="generate-with-openssl-rand-base64-32"

# GitHub App
GITHUB_APP_ID="your-github-app-id"
GITHUB_APP_NAME="your-github-app-machine-name"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
xxx
-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET="generate-random-string"
GITHUB_APP_CLIENT_ID="your-github-app-client-id"
GITHUB_APP_CLIENT_SECRET="your-github-app-client-secret"

# Resend (email for magic link auth)
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="leme CMS <cms@leme.nl>"

# Cache TTL (minutes)
# FILE_CACHE_TTL=1440
# PERMISSION_CACHE_TTL=60

# Cron endpoint secret
CRON_SECRET="generate-random-string"
