{
  "name": "pagescms",
  "description": "A user-friendly CMS for Next.js, Astro, Hugo, Nuxt, Jekyll or any other static site generator.",
  "license": "MIT",
  "author": {
    "name": "Ronan Berder"
  },
  "version": "2.1.6",
  "private": true,
  "type": "module",
  "scripts": {
    "setup:github-app": "node scripts/setup-github-app.mjs",
    "dev": "vinext dev",
    "dev:next": "next dev",
    "build": "vinext build",
    "build:next": "next build",
    "start": "vinext start",
    "start:next": "next start",
    "deploy": "vinext deploy --env production",
    "deploy:staging": "vinext deploy --env staging",
    "cf:check": "vinext deploy --dry-run --env production",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "vinext lint",
    "lint:next": "next lint",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx wrangler d1 migrations apply pages-cms-db --remote",
    "db:migrate:local": "npx wrangler d1 migrations apply pages-cms-db --local",
    "auth:generate": "npx @better-auth/cli generate --config ./lib/auth.ts --output ./auth-schema.ts --yes",
    "db:clear-cache": "npx tsx db/scripts/clear-cache.ts",
    "db:collaborators:export": "npx tsx db/scripts/collaborators/export.ts",
    "db:collaborators:import": "npx tsx db/scripts/collaborators/import.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/legacy-modes": "^6.4.0",
    "@codemirror/lint": "^6.8.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@hookform/resolvers": "^3.10.0",
    "@ltd/j-toml": "^1.38.0",
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "@react-email/components": "^1.0.7",
    "@tanstack/react-table": "^8.17.3",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-table-cell": "^3.20.0",
    "@tiptap/extension-table-header": "^3.20.0",
    "@tiptap/extension-table-row": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/markdown": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "@uiw/codemirror-theme-github": "^4.22.1",
    "@uiw/codemirror-theme-vscode": "^4.25.9",
    "@uiw/codemirror-theme-xcode": "^4.25.9",
    "@uiw/react-codemirror": "^4.22.1",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.45.1",
    "joplin-turndown-plugin-gfm": "^1.0.12",
    "lodash.merge": "^4.6.2",
    "lodash.mergewith": "^4.6.2",
    "lucide-react": "^0.563.0",
    "marked": "^17.0.1",
    "next": "^16.2.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "resend": "^6.9.1",
    "slugify": "^1.6.6",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.4.0",
    "tippy.js": "^6.3.7",
    "turndown": "^7.2.0",
    "use-debounce": "^10.0.0",
    "vinext": "^0.0.28",
    "yaml": "^2.4.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.27.0",
    "@cloudflare/workers-types": "^4.20260101.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/lodash.merge": "^4.6.9",
    "@types/lodash.mergewith": "^4.6.9",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.4",
    "@vitejs/plugin-rsc": "^0.5.21",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.6",
    "react-server-dom-webpack": "^19.2.4",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.4.5",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.72.0"
  }
}
